# EmailJS Configuration
# Get these from https://dashboard.emailjs.com

# Your EmailJS Public Key (found in Account > API Keys)
VITE_EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY

# Your EmailJS Service ID (e.g., service_xxxxx)
VITE_EMAILJS_SERVICE_ID=YOUR_SERVICE_ID

# Your EmailJS Template ID (e.g., template_xxxxx)
VITE_EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID

# Your email address where messages will be sent
VITE_CONTACT_EMAIL=your-email@gmail.com
